rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - location: string (required)
    //   - parentTask: string (optional)
    //   - name: string (required)
    //   - startDate: string (required, ISO date)
    //   - finishDate: string (required, ISO date)
    //   - siteUpdateDate: string (optional, ISO date)
    //   - report: string (optional)
    //   - startDateRequest: map (optional) { requestedDate: string, status: string }
    //   - finishDateRequest: map (optional) { requestedDate: string, status: string }
    //   - uid: string (required) - Owner ID
    //
    // Collection: cloudData
    // Document ID: code
    // Fields:
    //   - code: string
    //   - parentTask: string
    //   - location: string
    //   - name: string
    //   - startDate: string
    //   - finishDate: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    function isValidTask(data) {
      return data.keys().hasAll(['code', 'location', 'name', 'startDate', 'finishDate', 'uid']) &&
             data.code is string && data.code.size() > 0 && data.code.size() < 100 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             isValidDateString(data.startDate) &&
             isValidDateString(data.finishDate) &&
             data.uid == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "namhung07164@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{path=**}/taka_projects/{id} {
      allow read: if true;
    }

    match /{path=**}/taka_tasks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && uidNotModified() && (isDocOwner() || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
